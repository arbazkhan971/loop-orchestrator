{
  "name": "loop-orchestrator",
  "version": "0.2.0",
  "description": "Open-source tmux AI agent team orchestrator for Claude Code, Codex, Gemini CLI, and custom terminal coding agents.",
  "type": "module",
  "license": "MIT",
  "homepage": "https://github.com/arbazkhan971/loop-orchestrator#readme",
  "bugs": {
    "url": "https://github.com/arbazkhan971/loop-orchestrator/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/arbazkhan971/loop-orchestrator.git"
  },
  "publishConfig": {
    "access": "public"
  },
  "bin": {
    "loop": "./dist/cli.js",
    "loop-orchestrator": "./dist/cli.js"
  },
  "files": [
    "assets",
    "dist",
    "README.md",
    "LICENSE",
    "docs",
    "examples"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx src/cli.ts",
    "test": "vitest run",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "validate": "npm run typecheck && npm run test && npm run build"
  },
  "keywords": [
    "ai-agents",
    "agent-orchestrator",
    "tmux-orchestrator",
    "tmux",
    "claude-code",
    "claude",
    "codex",
    "openai-codex",
    "gemini-cli",
    "gemini",
    "multi-agent",
    "multi-agent-system",
    "agentic-coding",
    "coding-agent",
    "autonomous-coding-agents",
    "autonomous-agents",
    "ai-engineering-team",
    "ai-team",
    "devtools",
    "developer-tools",
    "terminal-agents",
    "terminal",
    "cli",
    "workflow-automation",
    "github-automation",
    "software-engineering-agents",
    "ai-code-review",
    "ai-workflow",
    "llm-agents"
  ],
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "commander": "^14.0.1",
    "yaml": "^2.8.1",
    "zod": "^4.1.13"
  },
  "devDependencies": {
    "@types/node": "^24.10.1",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3",
    "vitest": "^4.0.15"
  }
}
